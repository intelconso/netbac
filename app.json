{
  "expo": {
    "name": "NETBAC",
    "slug": "netbac",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "netbac",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.halalapps.netbac"
    },
    "android": {
      "package": "com.halalapps.netbac",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#10B981"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": []
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "NETBAC a besoin de la caméra pour photographier les supports."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#10B981"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
